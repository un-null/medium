import { BlockToJSX } from "~/components/blocks/block-to-jsx";

import { getHome } from "~/lib/notion";

const blocks = await getHome();
---

<RootLayout>
  <!-- <Card
    className="mx-auto grid aspect-square w-[75%] max-w-sm place-content-center border-zinc-600 bg-[#191919]"
  >
    ...
  </Card> -->

  <ul class="mx-auto max-w-screen-sm px-4 text-sm text-zinc-200 sm:text-base">
    {blocks.map((block) => <BlockToJSX block={block} />)}
  </ul>
</RootLayout>
