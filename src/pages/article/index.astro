---
import RootLayout from "~/layouts/root-layout.astro";

import { Image } from "astro:assets";
import { getArticles } from "~/lib/notion";
import { Card, CardContent, CardFooter } from "~/components/ui/card";

const articles = await getArticles();
---

<RootLayout title="Article">
  <ul class="grid grid-cols-2 gap-4 px-4 md:grid-cols-3">
    {
      articles.map((article) => (
        <Card className="bg-zinc-900/50 border-zinc-600">
          <a href={`/article/${article.id}`}>
            <CardContent className="grid aspect-[4/3] place-items-center bg-zinc-950 rounded-t-lg">
              <p class="mt-4 text-base md:text-lg">{article.title}</p>
            </CardContent>
            <CardFooter className="flex items-center justify-center space-x-2 text-sm text-zinc-500 mt-6">
              <p>編纂員: {article?.name}</p>
              <Image
                src={article?.avatar!}
                width={20}
                height={20}
                alt={article?.name}
                class="rounded-full"
              />
            </CardFooter>
          </a>
        </Card>
      ))
    }
  </ul>
</RootLayout>
