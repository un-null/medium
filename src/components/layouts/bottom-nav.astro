---
import { Card } from "../ui/card";
import { LucideIcon } from "../layouts/lucide-icon";

const active = Astro.url.pathname;

const navItems = [
  {
    href: "/",
    icon: "home",
  },
  {
    href: "/article/",
    icon: "article",
  },
  {
    href: "/works/",
    icon: "work",
  },
  {
    href: "/vlog/",
    icon: "vlog",
  },
  {
    href: "/contact/",
    icon: "contact",
  },
];
---

<nav class="text-notion-tag-gray sticky bottom-8 mx-auto">
  <Card className="border-zink-8 flex space-x-6 rounded-full px-6 py-3">
    {
      navItems.map((item) => (
        <a href={item.href}>
          <LucideIcon type={item.icon} isActive={active === item.href} />
        </a>
      ))
    }
  </Card>
</nav>
